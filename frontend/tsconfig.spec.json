{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "module": "CommonJS",
    "target": "ES2022", 
    "types": ["jest", "node"],
    "allowJs": true,          // Required for ts-jest to process .mjs files
    "esModuleInterop": true,  // Required for ESM/CJS interop
    "skipLibCheck": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.spec.ts", "src/**/*.d.ts", "setup-jest.ts"]
}

